{
  "root": "frontend/out",
  "clean_urls": true,
  "https_only": true,
  "headers": {
    "/_next/static/**": { "Cache-Control": "public, max-age=31536000, immutable" },
    "/assets/**": { "Cache-Control": "public, max-age=86400" },
    "/media/**": { "Cache-Control": "public, max-age=86400" },
    "/**": { "Cache-Control": "public, max-age=300" }
  },
  "error_page": "404.html"
}
