import { notFound } from 'next/navigation';
import Link from 'next/link';
import { getContentByCategory } from '@/lib/content';

interface CategoryPageProps {
  params: Promise<{
    category: string;
  }>;
}

export default async function CategoryPage({ params }: CategoryPageProps) {
  const { category } = await params;
  const content = await getContentByCategory(category);

  if (!content || content.length === 0) {
    notFound();
  }

  // Format category title
  const categoryTitle = category
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');

  return (
    <div className="max-w-4xl">
      <div className="mb-8">
        <h1 className="text-4xl font-bold text-slds-gray-900 mb-4">
          {categoryTitle}
        </h1>
        <p className="text-lg text-slds-gray-600">
          Browse all {categoryTitle.toLowerCase()} documentation
        </p>
      </div>

      <div className="grid gap-6">
        {content.map((item) => (
          <Link
            key={item.metadata.slug}
            href={`/${item.metadata.slug}`}
            className="block p-6 border border-slds-gray-200 rounded-lg hover:border-slds-blue-400 hover:shadow-md transition-all"
          >
            <h2 className="text-xl font-semibold text-slds-gray-900 mb-2">
              {item.metadata.title}
            </h2>
            {item.metadata.description && (
              <p className="text-slds-gray-600">{item.metadata.description}</p>
            )}
          </Link>
        ))}
      </div>

      {content.length === 0 && (
        <div className="text-center py-12">
          <p className="text-slds-gray-600">No content found in this category.</p>
        </div>
      )}
    </div>
  );
}

export async function generateStaticParams() {
  // This would be populated with actual categories from your content
  return [];
}
