# Server
NODE_ENV=development
PORT=4000
SESSION_SECRET=change-me-to-a-random-secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ldss_cms

# GitHub OAuth
# Register an OAuth App at: https://github.com/settings/applications/new
# Set the callback URL to: http://localhost:4000/auth/github/callback
GHE_CLIENT_ID=your-oauth-app-client-id
GHE_CLIENT_SECRET=your-oauth-app-client-secret
GHE_CALLBACK_URL=http://localhost:4000/auth/github/callback

# For GitHub Enterprise, uncomment and set:
# GHE_BASE_URL=https://git.soma.salesforce.com

# Target repository for content (commits and PRs go here)
GITHUB_OWNER=your-github-username
GITHUB_REPO=ldss-oss
GITHUB_CONTENT_PATH=content

# Cloudinary (image CDN)
# Heroku: provision with `heroku addons:create cloudinary:starter` — sets CLOUDINARY_URL automatically
# Local: copy the URL from `heroku config:get CLOUDINARY_URL -a <app>` or sign up at cloudinary.com
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
# Optional folder prefix to keep dev and prod uploads separate in the same account
CLOUDINARY_UPLOAD_FOLDER=ldss-cms-dev

# Figma (used to fetch frame thumbnails for the :::figma directive)
# Generate a personal access token at https://www.figma.com/settings (Personal access tokens)
FIGMA_ACCESS_TOKEN=

# Zeroheight (used by scripts/zeroheight-audit.ts to compare against migrated content)
# Settings → Tokens in your zeroheight workspace
ZEROHEIGHT_API_TOKEN=
ZEROHEIGHT_CLIENT_ID=
# Workspace styleguide ID (find in your styleguide URL: zeroheight.com/<id>/v/...)
ZEROHEIGHT_STYLEGUIDE_ID=
