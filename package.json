{
  "name": "lightning-design-system-cms",
  "version": "1.0.0",
  "description": "CMS backend for Lightning Design System documentation",
  "main": "dist/server.js",
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:setup": "psql -U postgres -f schema.sql",
    "tokens:generate": "ts-node --transpile-only scripts/build-tokens.ts",
    "heroku-postbuild": "bash scripts/heroku-postbuild.sh"
  },
  "keywords": [
    "cms",
    "express",
    "salesforce",
    "github"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@octokit/rest": "^20.0.2",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.5",
    "@types/passport": "^1.0.16",
    "@types/passport-oauth2": "^1.4.15",
    "@types/pg": "^8.11.0",
    "cloudinary": "^2.10.0",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.7.0",
    "pg": "^8.11.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@salesforce-ux/design-system": "^2.29.2",
    "@salesforce-ux/design-system-2": "^2.0.0"
  }
}
